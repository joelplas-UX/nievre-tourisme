rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Events: publiek leesbaar, admin kan zichtbaarheid aan/uit zetten
    match /morvan/data/events/{doc} {
      allow read: if true;
      allow update: if request.auth != null; // admin: toggle hidden
      allow create, delete: if false;        // alleen via Netlify Function (Admin SDK)
    }

    // Activiteiten: publiek leesbaar, admin kan aanmaken + bewerken
    match /morvan/data/activities/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Scrapebronnen: alleen ingelogde admin
    match /morvan/data/scrape_sources/{doc} {
      allow read, write: if request.auth != null;
    }

    // Scrape run logs: admin mag lezen, schrijven alleen via Admin SDK
    match /morvan/data/scrape_runs/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Activity sync logs: admin mag lezen, schrijven alleen via Admin SDK
    match /morvan/data/activity_syncs/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Inzendingen: publiek aanmaken, admin mag lezen + verwijderen
    match /morvan/data/submissions/{doc} {
      allow create: if true;
      allow read, delete: if request.auth != null;
      allow update: if false;
    }
  }
}
